{
  "name": "codecov-mcp",
  "version": "0.1.0",
  "description": "Complete Codecov API coverage for AI agents via Model Context Protocol",
  "author": "ScottN-PV",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codecov-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "cross-env INTEGRATION=true vitest run tests/integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "codecov",
    "mcp",
    "model-context-protocol",
    "coverage",
    "testing",
    "claude-code",
    "ai-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ScottN-PV/codecov-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ScottN-PV/codecov-mcp/issues"
  },
  "homepage": "https://github.com/ScottN-PV/codecov-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
